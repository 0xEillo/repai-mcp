# Rep AI Insights MCP configuration
# Copy to .env and fill in values.

# demo = standalone demo Supabase project with synthetic seed data
# prod = your own Rep AI Supabase project (credentials required below)
REPAI_MCP_MODE=demo

# Required in prod mode and in demo mode unless demo credentials are baked in.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Bring your own key. Required for LLM-powered tools (persona analysis);
# read-only tools work without it.
OPENROUTER_API_KEY=

# Optional. OpenRouter model for LLM synthesis (Gemini Flash class by default).
# OPENROUTER_MODEL=google/gemini-flash-1.5

# Where tool-call audit records are appended (JSONL).
# Default: ~/.repai-mcp/audit.jsonl (or /data/audit.jsonl in Docker)
# REPAI_MCP_AUDIT_PATH=
